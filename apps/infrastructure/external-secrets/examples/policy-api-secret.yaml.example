# Example: ExternalSecret for Policy API
# Copy this file to your application directory and modify as needed
#
# This creates a Kubernetes Secret named "policy-api-secrets" in namespace "aster-policy"
# by fetching values from Vault path "secret/data/apps/policy-api"

apiVersion: external-secrets.io/v1beta1
kind: ExternalSecret
metadata:
  name: policy-api-secrets
  namespace: aster-policy
spec:
  # How often to sync (default: 1h)
  refreshInterval: 1h

  # Reference to ClusterSecretStore
  secretStoreRef:
    name: vault-backend
    kind: ClusterSecretStore

  # Target Kubernetes Secret to create/update
  target:
    name: policy-api-secrets
    creationPolicy: Owner
    deletionPolicy: Retain
    template:
      type: Opaque
      # Optional: Add labels/annotations to the created secret
      metadata:
        labels:
          app: policy-api
        annotations:
          managed-by: external-secrets

  # Data mapping from Vault to Kubernetes Secret
  data:
    # Map Vault key to Secret key
    - secretKey: DATABASE_URL
      remoteRef:
        key: apps/policy-api           # Vault path (relative to secret/)
        property: database_url         # Key within the Vault secret

    - secretKey: DATABASE_PASSWORD
      remoteRef:
        key: apps/policy-api
        property: database_password

    - secretKey: API_KEY
      remoteRef:
        key: apps/policy-api
        property: api_key

    - secretKey: JWT_SECRET
      remoteRef:
        key: apps/policy-api
        property: jwt_secret

---
# Alternative: Fetch all keys from a Vault path
# Use dataFrom instead of data to fetch all keys at once

