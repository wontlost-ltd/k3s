# Example: Shared Database Credentials
# Use ClusterExternalSecret to sync the same secret to multiple namespaces

apiVersion: external-secrets.io/v1beta1
kind: ClusterExternalSecret
metadata:
  name: postgres-credentials
spec:
  # Namespaces to sync the secret to
  namespaceSelector:
    matchLabels:
      database-access: "true"
  # Or specify namespaces explicitly:
  # namespaceSelectors:
  #   - matchExpressions:
  #       - key: kubernetes.io/metadata.name
  #         operator: In
  #         values: [aster-policy, authentik, wontlost-data]

  # Refresh interval
  refreshTime: 1h

  # ExternalSecret template
  externalSecretSpec:
    secretStoreRef:
      name: vault-backend
      kind: ClusterSecretStore
    target:
      name: postgres-credentials
      creationPolicy: Owner
    data:
      - secretKey: POSTGRES_HOST
        remoteRef:
          key: infrastructure/postgres
          property: host

      - secretKey: POSTGRES_PORT
        remoteRef:
          key: infrastructure/postgres
          property: port

      - secretKey: POSTGRES_USER
        remoteRef:
          key: infrastructure/postgres
          property: username

      - secretKey: POSTGRES_PASSWORD
        remoteRef:
          key: infrastructure/postgres
          property: password

---
# To use this, label your namespaces:
# kubectl label namespace aster-policy database-access=true
# kubectl label namespace authentik database-access=true
