# Example: ExternalSecret for Authentik
# This replaces the manually created authentik-secrets
#
# Store in Vault: vault kv put secret/infrastructure/authentik \
#   secret_key="$(openssl rand -base64 36)" \
#   postgresql_password="your-password" \
#   bootstrap_password="admin-password"

apiVersion: external-secrets.io/v1beta1
kind: ExternalSecret
metadata:
  name: authentik-secrets
  namespace: authentik
spec:
  refreshInterval: 1h
  secretStoreRef:
    name: vault-backend
    kind: ClusterSecretStore
  target:
    name: authentik-secrets
    creationPolicy: Owner
  data:
    - secretKey: AUTHENTIK_SECRET_KEY
      remoteRef:
        key: infrastructure/authentik
        property: secret_key

    - secretKey: AUTHENTIK_POSTGRESQL__HOST
      remoteRef:
        key: infrastructure/authentik
        property: postgresql_host
        # Use default if not set in Vault
      # Optional: set a default value
      # decodingStrategy: None

    - secretKey: AUTHENTIK_POSTGRESQL__PORT
      remoteRef:
        key: infrastructure/authentik
        property: postgresql_port

    - secretKey: AUTHENTIK_POSTGRESQL__NAME
      remoteRef:
        key: infrastructure/authentik
        property: postgresql_name

    - secretKey: AUTHENTIK_POSTGRESQL__USER
      remoteRef:
        key: infrastructure/authentik
        property: postgresql_user

    - secretKey: AUTHENTIK_POSTGRESQL__PASSWORD
      remoteRef:
        key: infrastructure/authentik
        property: postgresql_password

    - secretKey: AUTHENTIK_BOOTSTRAP_PASSWORD
      remoteRef:
        key: infrastructure/authentik
        property: bootstrap_password

    - secretKey: AUTHENTIK_BOOTSTRAP_EMAIL
      remoteRef:
        key: infrastructure/authentik
        property: bootstrap_email
